NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for Super Admin (user management) and seed script
SUPABASE_SERVICE_ROLE_KEY=

# Super admin: comma-separated emails (app owner can manage all users)
# REQUIRED on Vercel: add this env var in Project Settings > Environment Variables
SUPER_ADMIN_EMAILS=owner@example.com

# One-time setup: set a random string, use at /setup-password to set your password when locked out, then remove
SETUP_SECRET=your-random-secret

# Base URL for password reset redirect (optional, defaults to localhost:3000)
# For password reset emails to work: add this URL + /auth/callback to Supabase Dashboard > Auth > URL Configuration > Redirect URLs
# e.g. http://localhost:3000/auth/callback (dev) or https://your-app.com/auth/callback (prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

