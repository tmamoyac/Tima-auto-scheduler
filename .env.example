NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for Super Admin (user management) and seed script
SUPABASE_SERVICE_ROLE_KEY=

# Super admin: comma-separated emails (app owner can manage all users)
# REQUIRED on Vercel: add this env var in Project Settings > Environment Variables
SUPER_ADMIN_EMAILS=owner@example.com

# One-time setup: set a random string, use at /setup-password to set your password when locked out, then remove
SETUP_SECRET=your-random-secret

# Base URL for password reset redirect (optional, defaults to localhost:3000)
# For password reset emails to work: add this URL + /auth/callback to Supabase Dashboard > Auth > URL Configuration > Redirect URLs
# e.g. http://localhost:3000/auth/callback (dev) or https://your-app.com/auth/callback (prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Schedule generation: defaults to CP-SAT.
# Production on Vercel/serverless: set SCHEDULER_CP_SOLVER_URL to a Python solver service (see docs/cp-sat-production.md).
# SCHEDULER_CP_SOLVER_URL=https://your-cp-sat-service.example.com
# SCHEDULER_CP_SOLVER_SECRET=shared-secret-matching-CP_SOLVER_SECRET-on-solver
# PoC — CP-SAT via Vercel Python Functions (api/cp_sat_vercel/*.py + root requirements.txt). Takes precedence over SCHEDULER_CP_SOLVER_URL when set.
# SCHEDULER_CP_MODE=vercel_python
# Optional: same value in Vercel env for the Python function if you enable auth below
# SCHEDULER_CP_VERCEL_PY_SECRET=random-shared-secret
# Override public URL for health/solve probes (defaults: VERCEL_URL, else NEXT_PUBLIC_APP_URL)
# SCHEDULER_VERCEL_PYTHON_BASE_URL=https://your-app.vercel.app
# Local / VM: install OR-Tools — python3 -m pip install -r scripts/requirements-cp.txt
# PYTHON=/usr/bin/python3   # optional override
# SCHEDULER_ENGINE=heuristic   # last-resort legacy search only; not recommended for prod quality
# CP_SAT_MAX_SECONDS=90

